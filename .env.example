# Copy this file to .env and fill in your values. Never commit the real .env file.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
# Used for AI local-market-demand analysis and the in-app chatbot.
# If left empty, the app falls back to deterministic estimates so it never breaks in a demo.
GEMINI_API_KEY=

# Port Flask/gunicorn binds to. Render sets this automatically in production.
PORT=5000

# Set to "true" for local development to enable Flask debug mode.
FLASK_DEBUG=false
